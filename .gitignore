profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or python versions,
#   it might cause conflict, write to ignore it.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions of dependencies
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains specific versions of dependencies
# .pdm-python
# .pdm-build/

# PIP / Conda Virtual Environments
.venv/
venv/
ENV/
env/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# Project specific data and models
# Keep directories but ignore files inside them
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
model/*
!model/.gitkeep

# OS generated files
.DS_Store
.DS_Store?
ehthumbs.db
Icon?
Thumbs.db
